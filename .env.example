# ─── Root Environment Variables ─────────────────────────────
# Copy this file to .env and fill in the values.
# The application runs in STANDALONE MODE with simulated data if no keys are provided.

# ─── Google Gemini AI (Optional) ────────────────────────────
# Enables real AI-generated threat explanations and incident narratives.
# If not set, the app uses built-in mock AI explanations automatically.
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Database (Optional) ────────────────────────────────────
# Defaults to SQLite at ./backend/sentinel.db if not set.
# Example for PostgreSQL: postgresql://user:password@localhost:5432/sentinelai
DATABASE_URL=sqlite:///./sentinel.db

# ─── Backend Server (Optional) ──────────────────────────────
# Port the FastAPI Uvicorn server runs on. Defaults to 8000.
BACKEND_PORT=8000

# ─── Frontend API Base URL (Optional) ───────────────────────
# Vite uses this to proxy API calls. Defaults to http://localhost:8000.
VITE_API_BASE_URL=http://localhost:8000
