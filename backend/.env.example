# ─── Backend Environment Variables ──────────────────────────
# Copy this file to backend/.env and fill in the values.

# Google Gemini API Key (Optional)
# Get yours free at: https://aistudio.google.com/app/apikey
# If absent, the app auto-uses built-in mock AI explanations.
GEMINI_API_KEY=your_gemini_api_key_here

# SQLAlchemy database URL (Optional)
# Defaults to sqlite:///./sentinel.db (local SQLite file)
DATABASE_URL=sqlite:///./sentinel.db

# Secret key for JWT token signing (change this in production)
SECRET_KEY=supersecret-changeme-in-production

# JWT token expiry in minutes (default: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60
