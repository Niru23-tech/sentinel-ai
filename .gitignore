# Root-level .gitignore for SentinelAI

# ─── Python / Backend ───────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments
venv/
env/
ENV/
.venv/
.env/

# Database files
*.db
*.sqlite
*.sqlite3
sentinel.db

# FastAPI / Uvicorn
*.log

# ─── Environment / Secrets ──────────────────────────────
.env
.env.*
!.env.example

# ─── Node / Frontend ────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local

# ─── Editor / IDE ───────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# ─── OS ─────────────────────────────────────────────────
*.tmp
*.bak
*.swp
